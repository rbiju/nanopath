# Python build / cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# uv / virtualenvs
.venv/
venv/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS junk
.DS_Store
Thumbs.db

# AI agent scratch (Claude Code worktrees, Codex, Cursor, Aider, Copilot, Cline, Continue)
.claude/
.codex/
.cursor/
.aider*
.copilot/
.cline/
.continue/

# Notebooks
.ipynb_checkpoints/

# Local env / secrets
.env
.env.*
*.pem
*.key

# Local run artifacts that should never end up in the repo
# (outputs/checkpoints/wandb/caches live under ${NANOPATH_DATA_DIR}, but guard against accidental local writes)
wandb/
outputs/
checkpoints/
*.pt
*.ckpt
*.log
slurm/
core.*

# Data + run outputs under the repo on off-cluster fresh clones, where
# prepare.py download=True rewrites absent /data + /block roots to nanopath/data/.
data/
preserved_run_logs/
